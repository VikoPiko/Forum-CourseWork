{
  "name": "forum-mse-2026-ui",
  "version": "0.1.0",
  "description": "Minimal Angular frontend for the Forum MSE 2026 teaching project (CI/CD, Docker, UAT exercises).",
  "private": true,
  "packageManager": "npm@10.9.2",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --proxy-config src/proxy.conf.json",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "test": "ng test",
    "test:ci": "ng test --watch=false",
    "lint": "eslint \"src/**/*.{ts,html}\" \"cypress/**/*.ts\"",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:ci": "start-server-and-test \"ng serve --port 4200 --proxy-config src/proxy.conf.json\" http-get://localhost:4200 \"cypress run\""
  },
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.11",
    "@angular/cli": "^21.2.11",
    "@angular/compiler-cli": "^21.2.0",
    "@types/node": "^22.10.0",
    "angular-eslint": "^21.0.0",
    "cypress": "^15.0.0",
    "eslint": "^9.18.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "start-server-and-test": "^2.0.10",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.20.0",
    "vitest": "^4.0.8"
  }
}
